			Tooltip: ""
		}

		ScrollWheelDirection: {
			Label: Направление прокрутки колеса мыши
			Tooltip: ""
		}

		npcsNotToForceDialectOn: {
			Label: Список НИПов без совместимости диалектов
			Tooltip: Изначально Terraria Origins включает совместимость диалектов для всех НИПов. Если это каким-то образом вызывает ошибки с вашими НИПами, вы можете воспользоваться этой настройкой для самостоятельной отладки.
		}

		ImproveChlorophyteBulletsPerformance: {
			Label: Исправление отображения хлорофитовых пуль
			Tooltip: Заменяет стандартное проблематичное отображение хлорофитовых пуль на более производительное и, возможно, более привлекательное.
		}

		OxfordComma: {
			Label: Оксфордская запятая
			Tooltip: Отображает оксфордскую (серийную) запятую во всех местах, где она должна быть.
			Comma: "[ox:,]"
		}

		DisableCoolVisualEffects: {
			Label: Отключить требовательные визуальные эффекты
			Tooltip:
				'''
				Некоторые эффекты Мерцающего Конструкта, его предметов, а также биом Стеклянной Рощи могут вызывать проблемы с производительностью на слабых устройствах
				Включите эту настройку, чтобы выключить и/или заменить их
				'''
		}

		DyeLightSources: {
			Label: Окрашивать источники света
			Tooltip: ""
		}

		ProceduralLightSourceDyeRate: {
			Label: Скорость окрашивания процедурных источников света
			Tooltip:
				'''
				Значение того, как часто неизвестные красители будут запрашивать информацию об освещении (в тиках на запрос)
				Установите 0, чтобы окрашивать источники света только известными красителями.
				Низкие значения показателя требуют производительных ПК
				'''
		}

