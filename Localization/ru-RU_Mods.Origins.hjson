		DisplayName: Поджигателя
		Description:
			'''
			Миньоны [buffhint/dnset foes ablaze:OnFire3]
			Миньоны взрываются перед смертью
			'''
		BadDescription: Миньоны со временем теряют здоровье
	}

	Brittle_Prefix.DisplayName: Хрупкий
	Speedy_Prefix.DisplayName: Стремительный
	Bloated_Prefix.DisplayName: Раздутый

	Wholesome_Prefix: {
		DisplayName: Полезный
		Description:
			'''
			Миньоны восстанавливают здоровье ближайших союзных игроков
			После смерти миньонов на их местах образуются сердца
			'''
	}

	Vampiric_Prefix: {
		DisplayName: Вампирский
		Description: Миньоны забирают жизнь у атакованных ими врагов
	}

	Necromantic_Prefix: {
		DisplayName: Некромантический
		SharedDescription:
			'''
			Миньоны наносят больше урона врагам с малым количеством здоровья
			Миньоны переводят здоровье врагов в некроману после их убийства
			Некромана не может быть восстановлена автоматически
			Некромана может быть использована только оружием призывателя
			'''
		Description: "{$Mods.Origins.Prefixes.Necromantic_Prefix.SharedDescription}"
	}

	Necromantic_Artifact_Prefix.Description: "{$Mods.Origins.Prefixes.Necromantic_Prefix.SharedDescription}"

	Defiled_Prefix: {
		DisplayName: "Осквернённый"
		Description: Снаряды крадут ману их носителю, а также иногда могут распадаться на осквернённые шипы
	}

	Debug_Tank_Rifle_Prefix.DisplayName: Удобная
}

