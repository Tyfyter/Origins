Spirit_Of_Christmas_Present: {
	DisplayName: Рождественский призрак настоящего

	TownNPCMood: {
		Content: Мне всё нравится.
		NoHome: Я ненавижу, когда у меня нет дома.
		FarFromHome: Я слишком далеко от дома.
		LoveSpace: Мне нравится, когда у меня так много места.
		DislikeCrowded: Мне не нравится, когда вокруг столько людей.
		HateCrowded: Я ненавижу, что вокруг настолько много людей.
		LikeNPC_Princess: Мне нравится {NPCName}.
		Princess_LovesNPC: Мне нравится {NPCName}.
	}
}

